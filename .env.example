# Cloudflare Turnstile Configuration
# Get your site key from: https://dash.cloudflare.com/?to=/:account/turnstile

# Turnstile Site Key (PUBLIC - visible in browser)
# For development/testing, use: 1x00000000000000000000AA (always passes)
# For production, use your real Cloudflare Turnstile site key
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Note: The site key is meant to be public and visible in the browser.
# The secret key (used for server-side verification) should NEVER be in frontend code.
